# ──────────────────────────────────────────────────────────────────────────────
# Copia este fichero a .env y rellena los valores.
# Genera SECRET_KEY con: python -c "import secrets; print(secrets.token_hex(32))"
# ──────────────────────────────────────────────────────────────────────────────

# Postgres
POSTGRES_USER=multifolio
POSTGRES_PASSWORD=change-me
POSTGRES_DB=multifolio

# App
SECRET_KEY=change-me-generate-with-secrets-token-hex-32
ENVIRONMENT=development   # production en deploy
ALLOWED_ORIGINS=http://localhost:3000

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OpenAI (SEO Suggestions)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
